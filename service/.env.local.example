# Local development — used by seed-local.ts
# Default is http://localhost:8000 so this file is optional.

AWS_ENDPOINT_URL=http://localhost:8000

# Required for SAM CLI to use Podman instead of Docker.
# Uncomment and set to your Podman socket path:
#   macOS:  unix://$HOME/.local/share/containers/podman/machine/podman.sock
#   Linux:  unix:///run/user/$UID/podman/podman.sock
# DOCKER_HOST=unix://...
