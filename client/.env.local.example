# Local development overrides — copy to .env.local
# These values point the client at the local SAM servers instead of production.

# REST API (daily challenge) — served by sam local start-api
VITE_DAILY_CHALLENGE_API_URL=http://localhost:3000

# WebSocket (multiplayer) — served by ws-proxy.ts, overrides Virgo region selection
VITE_WS_LOCAL_URL=ws://localhost:3001

# Disable analytics in local dev (optional)
VITE_CLARITY_PROJECT_ID=
